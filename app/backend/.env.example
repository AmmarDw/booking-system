# Copy to .env (git-ignored) and fill in real values. Never commit real values (NFR-3).
# .env is auto-loaded in dev via spring-dotenv; real environment variables always take precedence.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=booking_system
DB_USER=bookingadmin
DB_PASSWORD=changeme

# Google Cloud OAuth client (U4) — used for per-provider "Connect Google Calendar" (FR-13, M6)
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_REDIRECT_URI=http://localhost:8080/api/google/oauth2/callback
# Symmetric key used to encrypt providers' stored refresh tokens (GoogleAccountConnection.refreshTokenEnc)
TOKEN_ENCRYPTION_KEY=changeme
